{
  email {$ACME_EMAIL}
}

# Shared DNS-01 challenge config — Caddy gets the cert from Let's Encrypt
# by proving control of the domain via a Cloudflare DNS record, so the
# stack can run on a tailnet IP without a public port-80 reachable.
(cf_tls) {
  tls {
    dns cloudflare {env.CLOUDFLARE_API_TOKEN}
  }
}

# Dashboard
{$DASHBOARD_DOMAIN} {
  import cf_tls
  reverse_proxy dashboard:8080
  encode gzip
  log {
    output file /var/log/caddy/access.log {
      roll_size 10mb
      roll_keep 5
    }
  }
}

# Odysseus — self-hosted AI workspace (separate docker-compose project at
# /home/ojee/odysseus, binds 7000 to host).  Comment this out if you don't
# run Odysseus on the host.
{$ODYSSEUS_DOMAIN} {
  import cf_tls
  reverse_proxy host.docker.internal:7000
}

# n8n.  Serves a custom apple-touch-icon out of the dashboard because
# n8n doesn't ship one.
{$N8N_DOMAIN} {
  import cf_tls
  @apple path /apple-touch-icon.png /apple-touch-icon*.png /apple-touch-icon.svg
  handle @apple {
    rewrite * /n8n-apple-touch-icon.png
    reverse_proxy dashboard:8080
  }
  reverse_proxy n8n:5678
  encode gzip
}

# CouchDB for Obsidian (Self-hosted LiveSync plugin).  LiveSync does
# attachment streaming, so don't gzip — let CouchDB send raw JSON.
# Comment this block out if you don't run the Obsidian sync backend.
{$COUCHDB_DOMAIN} {
  import cf_tls
  reverse_proxy couchdb:5984
}
