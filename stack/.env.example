# Copy to .env and fill in real values. Never commit the real .env.
#
#   cp .env.example .env
#   vim .env
#   docker compose up -d --build

# Dashboard login password.
# Wrap in single quotes if it contains #, $, or spaces (otherwise docker
# compose .env parser may truncate at # or try to expand $VAR).
DASHBOARD_PASSWORD='change-me'

# Secret used to sign dashboard JWTs. Rotate to invalidate all existing sessions.
# Generate one with: openssl rand -hex 32
JWT_SECRET='change-me-to-a-long-random-string'

# Cloudflare API token for Caddy DNS-01 challenge.
# Scoped to: Zone.DNS:Edit on your domain only.
# Create at: https://dash.cloudflare.com/profile/api-tokens (template: "Edit zone DNS")
CLOUDFLARE_API_TOKEN=''

# n8n API key — lets the dashboard chat create/manage n8n workflows.
# Generate in n8n: Settings → n8n API → Create an API key
N8N_API_KEY=''

# Loq laptop code-agent (for launching Claude Code sessions from phone).
# Generated by ~/code-agent/install.sh on the Loq machine. Leave blank to
# disable the "Claude Code" panel.
CODE_AGENT_URL=http://100.81.241.55:7777
CODE_AGENT_TOKEN=''
