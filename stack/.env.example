# Copy to .env and fill in real values. Never commit the real .env.
#
#   cp .env.example .env
#   vim .env
#   docker compose up -d --build

# ─── Required ──────────────────────────────────────────────────────────

# Dashboard login password.  Wrap in single quotes if it contains #, $,
# or spaces (otherwise docker compose's .env parser may truncate it).
DASHBOARD_PASSWORD='change-me'

# Secret used to sign dashboard JWTs.  Rotate to invalidate sessions.
# Generate one with: openssl rand -hex 32
JWT_SECRET='change-me-to-a-long-random-string'

# Cloudflare API token for Caddy's DNS-01 challenge.  Needed because
# the stack binds to a tailnet IP (not public), so HTTP-01 won't work.
# Create at https://dash.cloudflare.com/profile/api-tokens with the
# "Edit zone DNS" template, scoped to your domain.
CLOUDFLARE_API_TOKEN=''

# Email Let's Encrypt registers your certs under.
ACME_EMAIL='you@example.com'

# ─── Networking ────────────────────────────────────────────────────────

# IP the Caddy reverse proxy binds to on the host.  Use your Tailscale
# IP to keep the stack tailnet-only (recommended), or 0.0.0.0 to expose
# it on every interface, or 127.0.0.1 for local-only.
BIND_IP=127.0.0.1

# IANA timezone for n8n schedule interpretation and dashboard chat
# (e.g. America/New_York, Europe/London, Asia/Tokyo).
TIMEZONE=UTC

# ─── Domains ───────────────────────────────────────────────────────────
# Each service runs on its own subdomain.  Point them all at your
# server (via DNS) before bringing the stack up.  Comment a block out
# in caddy/Caddyfile if you don't want that service exposed.

DASHBOARD_DOMAIN=agent.example.com
N8N_DOMAIN=flow.agent.example.com
COUCHDB_DOMAIN=sync.agent.example.com
# Odysseus (PewDiePie's self-hosted AI workspace) — leave empty to skip the
# subdomain, but you still need to run it as its own docker-compose project
# (see https://github.com/pewdiepie-archdaemon/odysseus) for the dashboard's
# Odysseus quick-link to do anything.
ODYSSEUS_DOMAIN=odysseus.agent.example.com

# Public URL the dashboard uses to reference itself (links in chat,
# n8n workflow URLs surfaced to the model, etc.).  Usually just
# https://$DASHBOARD_DOMAIN/.
DASHBOARD_BASE_URL=https://agent.example.com

# ─── Mounts ────────────────────────────────────────────────────────────

# Absolute host path to this `stack/` directory.  The dashboard reads
# files from here via /host-stack (e.g. so the chat agent can answer
# questions about docker-compose.yml).
HOST_STACK_PATH=/home/you/stack

# ─── Optional integrations ─────────────────────────────────────────────

# n8n API key — lets the dashboard chat create/manage workflows.
# Generate in n8n: Settings → n8n API → Create an API key.
N8N_API_KEY=''

# Claude Code agent (powers the dashboard's chat tab).  Install on the
# host with `code-agent/install.sh`, then point CODE_AGENT_URL at it.
# Leave empty to hide the chat tab.
CODE_AGENT_URL='http://host.docker.internal:7777'
CODE_AGENT_TOKEN=''

# CouchDB credentials for the Obsidian Self-hosted LiveSync backend.
# Username is created at first container start.
COUCHDB_USER=obsidian
COUCHDB_PASSWORD='change-me'
